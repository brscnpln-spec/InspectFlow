# Required — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional — set to "production" when deploying
NODE_ENV=development

# Optional — server port (default: 5000)
PORT=5000

# Seed passwords — required when running in development with an empty database.
# If omitted, random passwords are generated and printed to the console on first run.
# Change these to strong unique values; never commit the actual passwords.
SEED_ADMIN_PASSWORD=
SEED_MEMBER_PASSWORD=
